    <style>
        * { 
            font-family: "Pretendard Variable", Pretendard, -apple-system, BlinkMacSystemFont, system-ui, Roboto, "Helvetica Neue", "Segoe UI", "Apple SD Gothic Neo", "Noto Sans KR", "Malgun Gothic", "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol", sans-serif;
            -webkit-tap-highlight-color: transparent; 
        }
        
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        @keyframes slideIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }
        @keyframes slideInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes bounceIn { 
            0% { transform: scale(0.3); opacity: 0; } 
            50% { transform: scale(1.05); opacity: 1; } 
            70% { transform: scale(0.9); } 
            100% { transform: scale(1); } 
        }
        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        .animate-spin-slow { animation: spin 1s linear infinite; }
        
        /* [NEW] 연락처 위아래로 퉁퉁 튀는(bounce) 애니메이션 추가 */
        @keyframes softBounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-4px); } /* 이동 범위 축소 (-8px -> -4px) */
        }
        .animate-soft-bounce { display: inline-block; animation: softBounce 3.0s ease-in-out infinite; } /* 속도 더 천천히 (2.0s -> 3.0s) */
        
        /* [NEW] 둥둥 떠다니는 애니메이션 추가 */
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-4px); }
        }
        .animate-float { animation: float 2.5s ease-in-out infinite; }
        
        /* [NEW] 흔들림 애니메이션 추가 */
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-5px); }
            50% { transform: translateX(5px); }
            75% { transform: translateX(-5px); }
        }
        .animate-shake { animation: shake 0.3s ease-in-out; }
        
        /* [NEW] 달력 슬라이드 애니메이션 */
        @keyframes calendarSlideNext { from { opacity: 0; transform: translateX(15px); } to { opacity: 1; transform: translateX(0); } }
        @keyframes calendarSlidePrev { from { opacity: 0; transform: translateX(-15px); } to { opacity: 1; transform: translateX(0); } }
        .animate-calendar-next { animation: calendarSlideNext 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards; }
        .animate-calendar-prev { animation: calendarSlidePrev 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards; }
        
        .animate-slide-in { animation: slideIn 0.3s ease-out forwards; }
        .animate-slide-in-up { animation: slideInUp 0.3s ease-out forwards; }
        .animate-fade-in { animation: fadeIn 0.3s ease-out forwards; }
        .animate-bounce-in { animation: bounceIn 0.6s cubic-bezier(0.215, 0.610, 0.355, 1.000) forwards; }
        
        /* [NEW] 네온 테두리 애니메이션 (예약하기 버튼용) */
        @keyframes neonBorder {
            0% { box-shadow: 0 0 5px rgba(96, 165, 250, 0.2), inset 0 0 5px rgba(96, 165, 250, 0.1); border-color: rgba(96, 165, 250, 0.3); }
            50% { box-shadow: 0 0 15px rgba(96, 165, 250, 0.6), inset 0 0 10px rgba(96, 165, 250, 0.3); border-color: rgba(96, 165, 250, 0.8); }
            100% { box-shadow: 0 0 5px rgba(96, 165, 250, 0.2), inset 0 0 5px rgba(96, 165, 250, 0.1); border-color: rgba(96, 165, 250, 0.3); }
        }
        .animate-neon-border {
            animation: neonBorder 2.5s infinite ease-in-out;
            border-width: 2px; /* 테두리 두께 */
        }
        
        .terms-scroll::-webkit-scrollbar { width: 4px; }
        .terms-scroll::-webkit-scrollbar-track { background: #f1f1f1; }
        .terms-scroll::-webkit-scrollbar-thumb { background: #ccc; border-radius: 4px; }
        .terms-scroll::-webkit-scrollbar-thumb:hover { background: #aaa; }
        
        .safe-area-pb { padding-bottom: env(safe-area-inset-bottom); }
